{
  "info": {
    "name": "Smart Print Shop API - Final",
    "description": "Optimized Postman collection with Collection-level Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"jwt_token\", jsonData.access);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/login/" }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        { "name": "List Customers", "request": { "method": "GET", "url": { "raw": "{{base_url}}/customers/" } } },
        { "name": "Create Customer", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"name\": \"Alice\", \"email\": \"alice@example.com\"}" }, "url": { "raw": "{{base_url}}/customers/" } } }
      ]
    },
    {
      "name": "Orders",
      "item": [
        { "name": "List Orders", "request": { "method": "GET", "url": { "raw": "{{base_url}}/orders/" } } }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": { "type": "text/javascript", "exec": [""] }
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api", "type": "string" },
    { "key": "jwt_token", "value": "", "type": "string" }
  ]
}